{
  "generation_model": "gpt-5-nano",
  "evaluation_model": "gpt-5-nano",
  "reflection_model": "gpt-5-nano",
  "max_iters": 12,
  "feedback_minibatch_size": 2,
  "accept_margin": 0.15,
  "random_seed": 42,
  "early_stop_patience": 5,
  "early_stop_enabled": true,
  "diversity_threshold": 0.3,
  "diversity_enabled": true,
  "max_workers": 8,
  "parallel_evaluation": true,
  "hard_check_penalty": 1.2,
  "output_dir": "gepa_lite_runs",
  "trace_filename": "gepa_lite_run_trace.txt",
  "gold_standard_path": "scripts.json",
  "reference_example_limit": 3,
  "enable_disk_cache": true,
  "cache_schema_version": "topic_eval_v2",
  "cache_dirname": "api_cache",
  "print_prompt_each_iteration": true,
  "prompt_print_char_limit": 4000,
  "api_call_delay": 0.0,
  "max_retries": 3,
  "retry_base_delay": 1.0,
  "log_level": "INFO",
  "log_to_file": true,
  "seed_prompt": "Given the topic, generate a video script. Output valid JSON: {\"script\": \"...\", \"narration\": \"...\"}\nTopic: {topic}"
}